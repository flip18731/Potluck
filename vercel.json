      "NEXT_PUBLIC_INITIA_REST_URL": "https://lcd.testnet.initia.xyz",
      "NEXT_PUBLIC_INITIA_FAUCET_URL": "https://faucet.testnet.initia.xyz",
      "NEXT_PUBLIC_FEE_DENOM": "uinit"
