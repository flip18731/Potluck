# Server-only (never expose to client)
TREASURY_MNEMONIC=your-24-word-mnemonic-here
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Public — safe to expose
NEXT_PUBLIC_INITIA_CHAIN_ID=initiation-2
NEXT_PUBLIC_INITIA_RPC_URL=https://rpc.testnet.initia.xyz
NEXT_PUBLIC_INITIA_REST_URL=https://rest.testnet.initia.xyz
NEXT_PUBLIC_FEE_DENOM=uinit

# Treasury address (derived from TREASURY_MNEMONIC — run: node scripts/get-treasury-address.mjs)
NEXT_PUBLIC_TREASURY_ADDRESS=init1...

# CosmWasm pool contract (deployed to wasm-1 minitia — see contracts/README.md)
NEXT_PUBLIC_POOL_CONTRACT_ADDRESS=

# Initia Usernames registry
NEXT_PUBLIC_USERNAME_REGISTRY_ADDRESS=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
