# -----------------------------------------------------------------------------
# Server-only (never expose to client)
# -----------------------------------------------------------------------------

# 24-word mnemonic used by the backend treasury signer for reimbursements/settlement.
TREASURY_MNEMONIC=your-24-word-mnemonic-here

# Supabase service role key (required by API routes under src/app/api/pools/**).
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key


# -----------------------------------------------------------------------------
# Public client variables (safe to expose)
# -----------------------------------------------------------------------------

NEXT_PUBLIC_INITIA_CHAIN_ID=initiation-2
NEXT_PUBLIC_INITIA_RPC_URL=https://rpc.testnet.initia.xyz
NEXT_PUBLIC_INITIA_LCD_URL=https://lcd.testnet.initia.xyz
NEXT_PUBLIC_INITIA_REST_URL=https://lcd.testnet.initia.xyz
NEXT_PUBLIC_INITIA_FAUCET_URL=https://faucet.testnet.initia.xyz
NEXT_PUBLIC_FEE_DENOM=uinit

# Treasury address shown/used by client flows.
# Derive from mnemonic with: node scripts/get-treasury-address.mjs
NEXT_PUBLIC_TREASURY_ADDRESS=init1...

# Optional for CosmWasm mode. Keep blank when running treasury fallback.
NEXT_PUBLIC_POOL_CONTRACT_ADDRESS=

# Optional but recommended: enables username claim/resolve UX.
NEXT_PUBLIC_USERNAME_REGISTRY_ADDRESS=

# Supabase client keys
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
